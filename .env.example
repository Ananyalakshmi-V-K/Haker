APP_ENV=local
APP_URL=http://localhost:8000
SESSION_TTL_SECONDS=3600

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=guvi_app
MYSQL_USER=root
MYSQL_PASSWORD=

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=guvi_app
MONGO_PROFILE_COLLECTION=user_profiles
MONGO_HABIT_LOG_COLLECTION=habit_logs

REDIS_SCHEME=tcp
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_STREAK_CACHE_TTL=300
